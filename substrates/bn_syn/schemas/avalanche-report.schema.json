{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Avalanche Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "seed",
    "N",
    "dt_ms",
    "duration_ms",
    "steps",
    "bin_width_steps",
    "avalanche_count",
    "active_bin_fraction",
    "size_mean",
    "size_max",
    "duration_mean",
    "duration_max",
    "sizes",
    "durations",
    "nonempty_bins",
    "largest_avalanche_fraction",
    "size_variance",
    "duration_variance"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "seed": {"type": "integer"},
    "N": {"type": "integer", "minimum": 1},
    "dt_ms": {"type": "number", "exclusiveMinimum": 0},
    "duration_ms": {"type": "number", "minimum": 0},
    "steps": {"type": "integer", "minimum": 0},
    "bin_width_steps": {"type": "integer", "minimum": 1},
    "avalanche_count": {"type": "integer", "minimum": 0},
    "active_bin_fraction": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "size_mean": {"type": "number", "minimum": 0},
    "size_max": {"type": "integer", "minimum": 0},
    "duration_mean": {"type": "number", "minimum": 0},
    "duration_max": {"type": "integer", "minimum": 0},
    "sizes": {"type": "array", "items": {"type": "integer", "minimum": 1}},
    "durations": {"type": "array", "items": {"type": "integer", "minimum": 1}},
    "nonempty_bins": {"type": "integer", "minimum": 0},
    "largest_avalanche_fraction": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "size_variance": {"type": "number", "minimum": 0},
    "duration_variance": {"type": "number", "minimum": 0}
  }
}
