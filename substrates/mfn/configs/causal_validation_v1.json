{
  "schema_version": "mfn-causal-validation-v1",
  "calibration_date": "2026-03-21",
  "mode": "strict",
  "modes": {
    "strict": "Block report on error/fatal violations (default)",
    "strict_release": "Block report on any violation including warnings — release gate",
    "strict_api": "Block API response on error/fatal — runtime enforcement",
    "observe": "Log violations without blocking — development mode",
    "permissive": "Block only on fatal violations — experimental mode"
  },
  "severity_escalation": {
    "max_warnings_before_degraded": 5,
    "max_info_before_warning": 10,
    "fatal_always_blocks": true
  },
  "rules": {
    "SIM-001": {"stage": "simulate", "category": "numerical", "severity": "fatal", "description": "Field must be finite (no NaN/Inf)"},
    "SIM-002": {"stage": "simulate", "category": "numerical", "severity": "error", "description": "Field minimum within biophysical lower bound"},
    "SIM-003": {"stage": "simulate", "category": "numerical", "severity": "error", "description": "Field maximum within biophysical upper bound"},
    "SIM-004": {"stage": "simulate", "category": "structural", "severity": "fatal", "description": "History spatial shape matches field shape"},
    "SIM-005": {"stage": "simulate", "category": "numerical", "severity": "fatal", "description": "History must be finite"},
    "SIM-006": {"stage": "simulate", "category": "structural", "severity": "warn", "description": "Last history frame approximates final field"},
    "SIM-007": {"stage": "simulate", "category": "numerical", "severity": "error", "description": "Alpha within CFL stability limit"},
    "SIM-008": {"stage": "simulate", "category": "numerical", "severity": "error", "description": "Occupancy fractions sum to 1.0"},
    "SIM-009": {"stage": "simulate", "category": "numerical", "severity": "error", "description": "Effective inhibition non-negative"},
    "SIM-010": {"stage": "simulate", "category": "provenance", "severity": "warn", "description": "SimulationSpec attached for traceability"},
    "SIM-011": {"stage": "simulate", "category": "numerical", "severity": "error", "description": "MWC R-state fraction bounded [0,1] and monotonically increasing"},
    "EXT-001": {"stage": "extract", "category": "numerical", "severity": "fatal", "description": "Embedding non-empty and finite"},
    "EXT-002": {"stage": "extract", "category": "provenance", "severity": "error", "description": "Descriptor version set"},
    "EXT-003": {"stage": "extract", "category": "causal", "severity": "warn", "description": "Instability index consistent with field CV", "threshold": 0.01},
    "EXT-004": {"stage": "extract", "category": "contract", "severity": "error", "description": "Stability keys complete"},
    "EXT-005": {"stage": "extract", "category": "contract", "severity": "error", "description": "Complexity keys complete"},
    "EXT-006": {"stage": "extract", "category": "contract", "severity": "error", "description": "Connectivity keys complete"},
    "EXT-007": {"stage": "extract", "category": "numerical", "severity": "warn", "description": "Fractal dimension R2 quality >= 0.7", "threshold": 0.7},
    "DET-001": {"stage": "detect", "category": "numerical", "severity": "error", "description": "Anomaly score in [0, 1]"},
    "DET-002": {"stage": "detect", "category": "contract", "severity": "error", "description": "Anomaly label valid"},
    "DET-003": {"stage": "detect", "category": "contract", "severity": "error", "description": "Regime label valid"},
    "DET-004": {"stage": "detect", "category": "numerical", "severity": "error", "description": "Confidence in [0, 1]"},
    "DET-005": {"stage": "detect", "category": "contract", "severity": "warn", "description": "Contributing features subset of evidence keys"},
    "DET-006": {"stage": "detect", "category": "causal", "severity": "warn", "description": "Pathological noise requires noise evidence", "threshold": 0.1},
    "DET-007": {"stage": "detect", "category": "causal", "severity": "warn", "description": "Reorganized requires plasticity evidence", "threshold": 0.05},
    "DET-008": {"stage": "detect", "category": "causal", "severity": "info", "description": "Watch label near threshold margin", "threshold": 0.25},
    "FOR-001": {"stage": "forecast", "category": "contract", "severity": "error", "description": "Horizon >= 1"},
    "FOR-002": {"stage": "forecast", "category": "numerical", "severity": "error", "description": "Predicted states finite"},
    "FOR-004": {"stage": "forecast", "category": "contract", "severity": "error", "description": "Uncertainty envelope non-empty"},
    "FOR-005": {"stage": "forecast", "category": "contract", "severity": "error", "description": "Benchmark metrics required keys present"},
    "FOR-006": {"stage": "forecast", "category": "causal", "severity": "warn", "description": "Forecast structural error bounded", "threshold": 1.0},
    "FOR-007": {"stage": "forecast", "category": "numerical", "severity": "warn", "description": "Adaptive damping in valid range [0.80, 0.95]"},
    "FOR-008": {"stage": "forecast", "category": "causal", "severity": "warn", "description": "Forecast error monotonically increases with horizon"},
    "CMP-001": {"stage": "compare", "category": "numerical", "severity": "error", "description": "Distance non-negative"},
    "CMP-002": {"stage": "compare", "category": "numerical", "severity": "error", "description": "Cosine similarity in [-1, 1]"},
    "CMP-003": {"stage": "compare", "category": "contract", "severity": "error", "description": "Comparison label valid"},
    "CMP-004": {"stage": "compare", "category": "causal", "severity": "warn", "description": "Near-identical requires low distance", "threshold": 0.5},
    "CMP-005": {"stage": "compare", "category": "causal", "severity": "warn", "description": "Divergent requires low cosine", "threshold": 0.95},
    "CMP-006": {"stage": "compare", "category": "causal", "severity": "error", "description": "Topology-reorganization label mapping consistent"},
    "XST-001": {"stage": "cross_stage", "category": "causal", "severity": "warn", "description": "Stable regime should not produce anomalous label"},
    "XST-002": {"stage": "cross_stage", "category": "causal", "severity": "warn", "description": "Disabled neuromod implies zero plasticity", "threshold": 0.01},
    "XST-003": {"stage": "cross_stage", "category": "causal", "severity": "warn", "description": "Noise profile reorganized requires connectivity evidence", "threshold": 0.10},
    "XST-004": {"stage": "cross_stage", "category": "causal", "severity": "warn", "description": "Reorganized/critical regime requires plasticity evidence"},
    "XST-005": {"stage": "cross_stage", "category": "causal", "severity": "warn", "description": "Without neuromodulation, regime cannot be reorganized"},
    "PTB-001": {"stage": "perturbation", "category": "causal", "severity": "info", "description": "Anomaly label stable under 1e-6 noise perturbation"},
    "PTB-002": {"stage": "perturbation", "category": "causal", "severity": "info", "description": "Regime label stable under 1e-6 noise perturbation"}
  },
  "perturbation": {
    "enabled": false,
    "seeds": [1, 2, 3],
    "noise_amplitude": 1e-6,
    "stability_threshold": 0.95
  }
}
