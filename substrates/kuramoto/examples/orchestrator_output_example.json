{
  "module_sequence": [
    {
      "module_name": "data_ingestion",
      "operation": "ingest",
      "parameters": {
        "symbol": "BTC/USDT",
        "timeframe": "1h",
        "buffer_size": 1000
      },
      "priority": 0
    },
    {
      "module_name": "feature_extraction",
      "operation": "extract",
      "parameters": {
        "indicators": [
          "kuramoto",
          "ricci_flow",
          "entropy"
        ],
        "lookback": 100
      },
      "priority": 1
    },
    {
      "module_name": "risk_assessment",
