    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Unified production health indicator covering trading, data, incidents, and lifecycle gates.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "index": 0,
                  "text": "CRITICAL"
                },
                "1": {
                  "color": "orange",
                  "index": 1,
                  "text": "DEGRADED"
                },
                "2": {
                  "color": "green",
                  "index": 2,
                  "text": "HEALTHY"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "green",
                "value": 2
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": {}
      },
      "targets": [
        {
          "expr": "(\n  (sum(rate(tradepulse_orders_placed_total{status=\"error\"}[5m])) / sum(rate(tradepulse_orders_placed_total[5m])) < 0.015) and\n  (histogram_quantile(0.95, sum(rate(tradepulse_order_placement_duration_seconds_bucket[5m])) by (le)) < 0.35) and\n  (increase(tradepulse_data_ingestion_total{status=\"error\"}[10m]) == 0) and\n  (max(tradepulse_incidents_open{severity=\"critical\"}) == 0) and\n  (max(tradepulse_lifecycle_checkpoint_status{status=\"blocked\"}) == 0)\n) * 2 + (\n  (sum(rate(tradepulse_orders_placed_total{status=\"error\"}[5m])) / sum(rate(tradepulse_orders_placed_total[5m])) < 0.05) or\n  (histogram_quantile(0.95, sum(rate(tradepulse_order_placement_duration_seconds_bucket[5m])) by (le)) < 0.5) or\n  (max(tradepulse_incidents_open) <= 1)\n)",
          "legendFormat": "System Health",
          "refId": "A"
        }
      ],
      "title": "System Health Status",
      "type": "gauge"
    },
