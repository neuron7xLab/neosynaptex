{
  "version": 1,
  "groups": [
    {
      "name": "tradepulse.execution",
      "interval": "1m",
      "rules": [
        {
          "alert": "TradePulseOrderErrorRate",
          "expr": "sum(rate(tradepulse_orders_placed_total{status=\"error\"}[5m])) / sum(rate(tradepulse_orders_placed_total[5m])) > 0.05",
          "for": "5m",
          "labels": {
            "severity": "critical",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "High order error rate detected",
            "description": "More than 5% of orders failed in the last 5 minutes"
          }
        },
        {
          "alert": "TradePulseOrderLatency",
          "expr": "histogram_quantile(0.95, sum(rate(tradepulse_order_placement_duration_seconds_bucket[5m])) by (le)) > 2",
          "for": "10m",
          "labels": {
            "severity": "warning",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Order placement latency above 2 seconds",
            "description": "P95 order placement latency exceeded the target for 10 minutes"
          }
        },
        {
          "alert": "TradePulseOrderAckLatency",
          "expr": "tradepulse_order_ack_latency_quantiles_seconds{quantile=\"0.95\"} > 0.4",
          "for": "5m",
          "labels": {
            "severity": "warning",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Signal → ack latency breaching 400 ms",
            "description": "p95 signal to acknowledgement latency exceeded 400 ms for 5 minutes"
          }
        },
        {
          "alert": "TradePulseSignalToFillLatency",
          "expr": "tradepulse_signal_to_fill_latency_quantiles_seconds{quantile=\"0.99\"} > 0.65",
          "for": "5m",
          "labels": {
            "severity": "critical",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Signal → fill latency breaching 650 ms",
            "description": "p99 signal to fill latency exceeded 650 ms for 5 minutes"
          }
        }
      ]
    },
    {
      "name": "tradepulse.risk",
      "interval": "30s",
      "rules": [
        {
          "alert": "TradePulseKillSwitchEngaged",
          "expr": "tradepulse_risk_kill_switch == 1",
          "for": "0m",
          "labels": {
            "severity": "critical",
            "team": "trade-ops",
            "runbook": "docs/INCIDENT_RUNBOOK.md#1-kill-switch-triggered"
          },
          "annotations": {
            "summary": "Kill switch is ENGAGED - all trading halted",
            "description": "The global kill switch has been triggered. All order submissions are blocked. Immediate investigation required."
          }
        },
        {
          "alert": "TradePulseCircuitBreakerOpen",
          "expr": "tradepulse_risk_circuit_state{state=\"open\"} == 1",
          "for": "1m",
          "labels": {
            "severity": "warning",
            "team": "trade-ops",
            "runbook": "docs/INCIDENT_RUNBOOK.md#3-risk-engine-blocking"
          },
          "annotations": {
            "summary": "Circuit breaker is OPEN",
            "description": "The risk circuit breaker has tripped and is currently open. Orders may be blocked."
          }
        },
        {
          "alert": "TradePulseHighRejectionRate",
          "expr": "rate(tradepulse_risk_rejections_total[5m]) > 10",
          "for": "5m",
          "labels": {
            "severity": "warning",
            "team": "trade-ops",
            "runbook": "docs/INCIDENT_RUNBOOK.md#3-risk-engine-blocking"
          },
          "annotations": {
            "summary": "High order rejection rate by risk engine",
            "description": "More than 10 orders per minute are being rejected by the risk engine."
          }
        },
        {
          "alert": "TradePulseCircuitBreakerTrip",
          "expr": "increase(tradepulse_risk_circuit_trips_total[5m]) > 0",
          "for": "0m",
          "labels": {
            "severity": "warning",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Circuit breaker has tripped",
            "description": "The risk circuit breaker has been triggered at least once in the last 5 minutes."
          }
        },
        {
          "alert": "TradePulseHighDrawdown",
          "expr": "tradepulse_drawdown_percent > 5",
          "for": "10m",
          "labels": {
            "severity": "warning",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Portfolio drawdown exceeds 5%",
            "description": "Current portfolio drawdown has exceeded 5% for more than 10 minutes."
          }
        },
        {
          "alert": "TradePulseCriticalDrawdown",
          "expr": "tradepulse_drawdown_percent > 10",
          "for": "5m",
          "labels": {
            "severity": "critical",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Portfolio drawdown exceeds 10% - CRITICAL",
            "description": "Current portfolio drawdown has exceeded 10%. Risk limits may trigger kill switch."
          }
        }
      ]
    },
    {
      "name": "tradepulse.mode",
      "interval": "1m",
      "rules": [
        {
          "alert": "TradePulseModeTransition",
          "expr": "increase(tradepulse_trading_mode_transitions_total[5m]) > 0",
          "for": "0m",
          "labels": {
            "severity": "info",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Trading mode has changed",
            "description": "A trading mode transition occurred in the last 5 minutes. Verify this was intentional."
          }
        },
        {
          "alert": "TradePulseLiveModeActive",
          "expr": "tradepulse_trading_mode{mode=\"LIVE\"} == 1",
          "for": "0m",
          "labels": {
            "severity": "info",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "System is in LIVE trading mode",
            "description": "TradePulse is currently executing real trades. Ensure proper monitoring is active."
          }
        }
      ]
    },
    {
      "name": "tradepulse.data",
      "interval": "2m",
      "rules": [
        {
          "alert": "TradePulseDataIngestionFailures",
          "expr": "increase(tradepulse_data_ingestion_total{status=\"error\"}[10m]) > 0",
          "for": "0m",
          "labels": {
            "severity": "critical",
            "team": "data-pipeline"
          },
          "annotations": {
            "summary": "Data ingestion failure detected",
            "description": "At least one ingestion job reported errors in the last 10 minutes"
          }
        },
        {
          "alert": "TradePulseDataFreshness",
          "expr": "max(time() - tradepulse_data_ingestion_duration_seconds_sum / tradepulse_data_ingestion_duration_seconds_count) > 300",
          "for": "5m",
          "labels": {
            "severity": "warning",
            "team": "data-pipeline"
          },
          "annotations": {
            "summary": "Data ingestion freshness degraded",
            "description": "Average ingestion lag exceeded five minutes"
          }
        }
      ]
    },
    {
      "name": "tradepulse.strategy",
      "interval": "1m",
      "rules": [
        {
          "alert": "TradePulseBacktestFailures",
          "expr": "increase(tradepulse_backtest_total{status=\"error\"}[30m]) > 0",
          "for": "0m",
          "labels": {
            "severity": "warning",
            "team": "research"
          },
          "annotations": {
            "summary": "Backtest run failed",
            "description": "At least one strategy backtest ended with an error in the last 30 minutes"
          }
        },
        {
          "alert": "TradePulseOptimizationSlow",
          "expr": "avg(rate(tradepulse_optimization_duration_seconds_sum[30m]) / rate(tradepulse_optimization_duration_seconds_count[30m])) > 120",
          "for": "30m",
          "labels": {
            "severity": "info",
            "team": "research"
          },
          "annotations": {
            "summary": "Strategy optimisation running slowly",
            "description": "Average optimisation duration exceeded two minutes"
          }
        }
      ]
    },
    {
      "name": "tradepulse.model",
      "interval": "1m",
      "rules": [
        {
          "alert": "TradePulseModelLatencyHigh",
          "expr": "tradepulse_model_inference_latency_quantiles_seconds{quantile=\"p99\"} > 0.5",
          "for": "5m",
          "labels": {
            "severity": "warning",
            "team": "ml-ops",
            "runbook": "docs/INCIDENT_RUNBOOK.md#4-ml-errors-timeouts"
          },
          "annotations": {
            "summary": "ML model inference latency is high",
            "description": "p99 model inference latency exceeded 500ms for 5 minutes"
          }
        },
        {
          "alert": "TradePulseModelErrorRateHigh",
          "expr": "tradepulse_model_inference_error_ratio > 0.01",
          "for": "5m",
          "labels": {
            "severity": "warning",
            "team": "ml-ops",
            "runbook": "docs/INCIDENT_RUNBOOK.md#4-ml-errors-timeouts"
          },
          "annotations": {
            "summary": "ML model error rate exceeds 1%",
            "description": "Model inference error ratio has exceeded 1% for 5 minutes"
          }
        },
        {
          "alert": "TradePulseModelDegradation",
          "expr": "increase(tradepulse_model_quality_degradation_events_total[15m]) > 0",
          "for": "0m",
          "labels": {
            "severity": "warning",
            "team": "ml-ops"
          },
          "annotations": {
            "summary": "Model quality degradation detected",
            "description": "At least one model quality degradation event was emitted in the last 15 minutes"
          }
        }
      ]
    },
    {
      "name": "tradepulse.operations",
      "interval": "1m",
      "rules": [
        {
          "alert": "TradePulseCriticalIncidentOpen",
          "expr": "tradepulse_incidents_open{severity=\"critical\"} > 0",
          "for": "0m",
          "labels": {
            "severity": "critical",
            "team": "platform-ops"
          },
          "annotations": {
            "summary": "Critical incident requires response",
            "description": "At least one critical incident is open and unmitigated"
          }
        },
        {
          "alert": "TradePulseIncidentAckSLA",
          "expr": "histogram_quantile(0.5, sum(rate(tradepulse_incident_ack_latency_seconds_bucket[5m])) by (le, severity)) > 300",
          "for": "10m",
          "labels": {
            "severity": "warning",
            "team": "platform-ops"
          },
          "annotations": {
            "summary": "Median incident acknowledgement breached 5 minutes",
            "description": "Incident acknowledgement time exceeded the 5 minute SLA"
          }
        },
        {
          "alert": "TradePulseLifecycleCheckpointBlocked",
          "expr": "max by (checkpoint) (tradepulse_lifecycle_checkpoint_status{status=\"blocked\"}) == 1",
          "for": "5m",
          "labels": {
            "severity": "critical",
            "team": "platform-ops"
          },
          "annotations": {
            "summary": "Lifecycle checkpoint blocked",
            "description": "A lifecycle checkpoint is blocked for more than five minutes"
          }
        },
        {
          "alert": "TradePulseRunbookFailures",
          "expr": "increase(tradepulse_runbook_executions_total{outcome=\"failed\"}[15m]) > 0",
          "for": "0m",
          "labels": {
            "severity": "warning",
            "team": "platform-ops"
          },
          "annotations": {
            "summary": "Runbook execution failed",
            "description": "At least one production runbook failed in the last 15 minutes"
          }
        },
        {
          "alert": "TradePulseMetricsMissing",
          "expr": "absent(up{job=\"tradepulse\"})",
          "for": "5m",
          "labels": {
            "severity": "critical",
            "team": "platform-ops",
            "runbook": "docs/INCIDENT_RUNBOOK.md#5-metrics-logs-missing"
          },
          "annotations": {
            "summary": "TradePulse metrics are missing",
            "description": "Prometheus cannot scrape metrics from TradePulse. Service may be down or unreachable."
          }
        }
      ]
    }
  ]
}
