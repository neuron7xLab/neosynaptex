{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tradepulse.events.prediction_completed.v1",
  "title": "PredictionCompletedEvent",
  "description": "Webhook payload emitted when an asynchronous prediction is complete.",
  "type": "object",
  "required": [
    "event_id",
    "schema_version",
    "request_id",
    "symbol",
    "completed_at",
    "prediction"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Globally unique identifier for deduplication."
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the webhook contract."
    },
    "request_id": {
      "type": "string",
      "description": "Identifier returned in the submission acknowledgement."
    },
    "symbol": {
      "type": "string",
      "description": "Instrument symbol."
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp indicating when inference completed."
    },
    "prediction": {
      "type": "object",
      "required": [
        "horizon_minutes",
        "value",
        "confidence"
      ],
      "properties": {
        "horizon_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "value": {
          "type": "number"
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "distribution": {
          "type": "object",
          "properties": {
            "p05": { "type": "number" },
            "p50": { "type": "number" },
            "p95": { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      },
      "default": {}
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "event_id": "evt-20250201-001",
      "schema_version": "1.0.0",
      "request_id": "pred-20250201-001",
      "symbol": "ETH-USD",
      "completed_at": "2025-02-01T12:32:10Z",
      "prediction": {
        "horizon_minutes": 15,
        "value": 2498.65,
        "confidence": 0.74,
        "distribution": {
          "p05": 2445.10,
          "p50": 2498.65,
          "p95": 2555.90
        }
      },
      "metadata": {
        "trace_id": "trace-abc123"
      }
    }
  ]
}
