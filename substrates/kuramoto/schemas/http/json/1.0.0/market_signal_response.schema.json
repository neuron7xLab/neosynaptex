{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tradepulse.http.market_signal_response.v1",
  "title": "MarketSignalResponse",
  "description": "Latest trading signal snapshot exposed by the public API.",
  "type": "object",
  "required": [
    "symbol",
    "as_of",
    "signal",
    "confidence",
    "horizon_minutes"
  ],
  "properties": {
    "symbol": {
      "type": "string",
      "description": "Canonical instrument symbol (e.g. BTC-USD)."
    },
    "as_of": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of the signal measurement in RFC 3339 format."
    },
    "signal": {
      "type": "string",
      "enum": [
        "BUY",
        "SELL",
        "HOLD"
      ],
      "description": "Directional recommendation derived from current features."
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Normalized signal confidence bounded between 0 and 1."
    },
    "horizon_minutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1440,
      "description": "Time horizon the signal is expected to remain valid for."
    },
    "ttl_seconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0,
      "description": "Optional server-defined TTL for cache alignment."
    },
    "metadata": {
      "type": "object",
      "description": "Free-form metadata surface for provider-specific hints.",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      },
      "default": {}
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "symbol": "BTC-USD",
      "as_of": "2025-02-01T12:30:00Z",
      "signal": "BUY",
      "confidence": 0.82,
      "horizon_minutes": 30,
      "ttl_seconds": 90,
      "metadata": {
        "market": "crypto",
        "venue": "BINANCE"
      }
    }
  ]
}
