{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BundleManifest",
  "version": "v1",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "engine_version": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "artifacts": {
      "type": "object"
    },
    "checksums": {
      "type": "object"
    },
    "signature": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "schema_version",
    "engine_version",
    "run_id"
  ]
}