[importlinter]
root_packages =
    core
    contracts
    evl
include_external_packages = True

# === Layer 1: Core must not depend on substrates, agents, or evl ===
[importlinter:contract:core_isolation]
name = Core must not depend on substrates, agents, or evl
type = forbidden
source_modules =
    core.axioms
    core.contracts
    core.block_bootstrap
    core.iaaft
    core.multiverse
    core.failure_regimes
forbidden_modules =
    substrates
    agents
    evl

# === Layer 2: Contracts must not depend on substrates or evl ===
[importlinter:contract:contracts_isolation]
name = Contracts must not depend on substrates or evl
type = forbidden
source_modules =
    contracts.invariants
forbidden_modules =
    substrates
    agents
    evl

# === Layer 3: EVL must not depend on substrates ===
[importlinter:contract:evl_isolation]
name = EVL must not depend on substrates
type = forbidden
source_modules =
    evl.analyze
    evl.collector
    evl.dfa
    evl.effect_size
    evl.aggregator
forbidden_modules =
    substrates
    agents
